<odoo>

    <record id="view_project_task_form_inherit" model="ir.ui.view">
        <field name="name">view.project.task.form.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/div[@name='button_box']/button[@name='action_dependent_tasks']" position="after">
                <button name="action_open_access_requests" type="object"
                        class="oe_stat_button" icon="fa-shield">
                    <field string="Access Requests" name="access_request_count" widget="statinfo"/>
                </button>
            </xpath>

        </field>
    </record>

</odoo>