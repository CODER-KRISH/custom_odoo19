<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_access_request_reason_form" model="ir.ui.view">
        <field name="name">access.request.reason.form</field>
        <field name="model">access.request.reason</field>
        <field name="arch" type="xml">
            <form string="Reject Access Request">
                <sheet>
                    <group>
                        <field name="request_id" readonly="1"/>
                        <field name="reason" required="1" placeholder="Enter rejection reason..."/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_confirm_rejection"
                            type="object"
                            string="Reject"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>