<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_subscription_order_list" model="ir.ui.view">
        <field name="name">subscription.order.list</field>
        <field name="model">subscription.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Reference"/>
                <field name="partner_id" string="Customer"/>
                <field name="account_manager_id" string="Sales Person"/>
                <field name="start_date" string="From"/>
                <field name="end_date" string="To"/>
                <field name="currency_id" nolabel="1" invisible="1"/>
                <field name="grand_total" string="Amount"/>
                <field name="state" string="Status" widget="badge" decoration-info="state == 'review'"
                       decoration-success="state == 'approved'" decoration-danger="state == 'expired'"
                />
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_subscription_order_form" model="ir.ui.view">
        <field name="name">subscription.order.form</field>
        <field name="model">subscription.order</field>
        <field name="arch" type="xml">
            <form string="Subscription Order">
                <header>
                    <button name="state_to_review"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                    />
                    <button name="state_to_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'review'"
                            groups="subscription_management.group_subs_admin"
                    />
                    <button name="print_order_receipt"
                            string="Download Receipt"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'approved'"
                    />
                    <button name="state_to_draft"
                            string="To Draft"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'draft'"
                            groups="subscription_management.group_subs_admin"
                    />
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,review,approved"
                           invisible="state in ['expired', 'cancelled']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved,expired"
                           invisible="state != 'expired'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,review,cancelled"
                           invisible="state != 'cancelled'"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <!--  Group for the normal User  -->
                        <group groups="!subscription_management.group_subs_admin">
                            <field name="partner_id" string="Customer" readonly="state != 'draft'" required="1"/>
                            <field name="account_manager_id" string="Account Manager" readonly="state != 'draft'"/>
                            <field name="start_date"
                                   string="Access Period"
                                   widget="daterange"
                                   readonly="state != 'draft'"
                                   options="{'end_date_field': 'end_date', 'always_range': true}" required="1"/>
                            <span class="o_form_label o_td_label o_address_type" name="address_name">
                                Address
                            </span>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street" readonly="1"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street" readonly="1"/>
                                <field name="city" placeholder="City" class="o_address_city" readonly="1"/>
                                <field name="state_id" placeholder="State" class="o_address_state"
                                       options="{'no_open': True, 'no_quick_create': True}"
                                       context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"
                                       readonly="1"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="1"/>
                                <div name="partner_address_country" class="d-flex justify-content-between">
                                    <field name="country_id" placeholder="Country" class="o_address_country"
                                           options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"
                                           readonly="1"/>
                                </div>
                            </div>
                            <field name="payment_term_id" readonly="state != 'draft'" string="Payment Terms"/>
                        </group>

                        <!--  Group for the Admin User  -->
                        <group groups="subscription_management.group_subs_admin">
                            <field name="partner_id" string="Customer" readonly="0" required="1"/>
                            <field name="account_manager_id" string="Account Manager" readonly="0"/>
                            <field name="start_date"
                                   string="Access Period"
                                   widget="daterange"
                                   readonly="0"
                                   options="{'end_date_field': 'end_date', 'always_range': true}" required="1"/>
                            <span class="o_form_label o_td_label o_address_type" name="address_name">Address</span>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street" readonly="0"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street" readonly="0"/>
                                <field name="city" placeholder="City" class="o_address_city" readonly="0"/>
                                <field name="state_id" placeholder="State" class="o_address_state"
                                       context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"
                                       readonly="0"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="0"/>
                                <div name="partner_address_country" class="d-flex justify-content-between">
                                    <field name="country_id" placeholder="Country" class="o_address_country"
                                           options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"
                                           readonly="0"/>
                                </div>
                            </div>
                            <field name="payment_term_id" readonly="0" string="Payment Terms"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Subscription Lines">
                            <field name="line_ids" readonly="0" groups="subscription_management.group_subs_admin">
                                <list editable="bottom" no_open="1">
                                    <field name="product_id"/>
                                    <field name="currency_id" nolabel="1" invisible="1"/>
                                    <field name="quantity"/>
                                    <field name="price_unit" widget="monetary"/>
                                    <field name="subtotal" widget="monetary"/>
                                </list>
                            </field>

                            <field name="line_ids" readonly="state != 'draft'"
                                   groups="!subscription_management.group_subs_admin">
                                <list editable="bottom" no_open="1">
                                    <field name="product_id"/>
                                    <field name="currency_id" nolabel="1" invisible="1"/>
                                    <field name="quantity"/>
                                    <field name="price_unit" widget="monetary"/>
                                    <field name="subtotal" widget="monetary"/>
                                </list>
                            </field>

                            <group col="4">

                                <group class="oe_subtotal_footer oe_right">
                                    <field name="currency_id" invisible="1"/>
                                    <span for="amount_total" style="font-size: 16px;">Total:</span>
                                    <field name="amount_total"
                                           string="Total"
                                           readonly="1"
                                           widget="monetary"
                                           nolabel="1"
                                           class="oe_inline fw-bold"
                                           style="font-weight: bold;"
                                    />
                                    <span for="discount" invisible="amount_total &gt;= 10000" style="font-size: 16px;">
                                        Discount:
                                    </span>
                                    <field name="discount"
                                           string="Discount"
                                           readonly="1"
                                           nolabel="1"
                                           invisible="amount_total &gt;= 10000"
                                           widget="monetary"
                                    />
                                    <span for="discount" invisible="amount_total &lt; 10000" style="font-size: 16px;">
                                        Discount 10%:
                                    </span>
                                    <field name="discount"
                                           string="Discount 10%"
                                           nolabel="1"
                                           invisible="amount_total &lt; 10000"
                                           widget="monetary"
                                    />
                                    <span for="grand_total" style="font-size: 16px;">Amount:</span>
                                    <field name="grand_total"
                                           string="Amount"
                                           nolabel="1"
                                           readonly="1"
                                           class="fw-bold"
                                           widget="monetary"
                                           style="font-weight: bold; font-size: 20px;"
                                    />

                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="subs_kanban_view" model="ir.ui.view">
        <field name="name">subs.kanban.view</field>
        <field name="model">subscription.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <templates>
                    <t t-name="card" style="gap: 10px;">
                        <div class="row mb4">
                            <field name="name" class="fw-bold"/>
                            <div>
                                <strong>Customer:&amp;nbsp;</strong>
                                <field name="partner_id"/>
                            </div>
                            <div>
                                <field name="line_ids" widget="many2many_tags"/>
                            </div>
                            <div style="display: flex; justify-content: flex-start; gap: 10px;">
                                <field name="start_date"
                                       string="Access Period"
                                       widget="daterange"
                                       readonly="state != 'draft'"
                                       options="{'end_date_field': 'end_date', 'always_range': true}" required="1"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_subscription_search" model="ir.ui.view">
        <field name="name">view.subscription.search</field>
        <field name="model">subscription.order</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Name" name="type" context="{'group_by':'name'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_subscription_order" model="ir.actions.act_window">
        <field name="name">Subscription Orders</field>
        <field name="res_model">subscription.order</field>
        <field name="view_mode">list,form,search,kanban</field>
    </record>

    <!-- Server Action -->
    <record id="action_order_to_draft" model="ir.actions.server">
        <field name="name">Set To Draft</field>
        <field name="model_id" ref="model_subscription_order"/>
        <field name="binding_model_id" ref="model_subscription_order"/>
        <field name="state">code</field>
        <field name="code">action = records.state_to_draft()</field>
    </record>

</odoo>