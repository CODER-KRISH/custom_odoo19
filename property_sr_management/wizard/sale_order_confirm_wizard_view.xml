<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="view_sale_order_confirm_wizard_form" model="ir.ui.view">
        <field name="name">view.sale.order.confirm.wizard.form</field>
        <field name="model">sale.order.confirm.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <h1><field name="message" readonly="1" nolabel="1"/></h1>
                </group>

                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
