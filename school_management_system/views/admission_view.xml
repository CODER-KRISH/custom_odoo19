<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="admission_form_view" model="ir.ui.view">
            <field name="name">admission.form.view</field>
            <field name="model">admission</field>
            <field name="arch" type="xml">
                <form string="Admission">
                    <header>
                        <button string="Create Admission"
                                name="action_create_student_admission"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'draft'"/>

                        <button string="Confirm Admission"
                                name="confirm_student_admission"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'approved'"/>

                        <button string="Update"
                                name="update_student_admission"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'in_admission'"/>

                        <button string="Terminate"
                                name="terminate_student_admission"
                                type="object"
                                class="btn-secondary"
                                invisible="state != 'in_admission'"/>

                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <h2>
                            <field name="admission_sequence" placeholder="Your Name" readonly="1"
                                   class="fw-bold fs-10"/>
                        </h2>
                        <h1>
                            <field name="user_id" placeholder="Your Name" readonly="state != 'draft'"/>
                        </h1>
                        <group>
                            <group string="Personal Information">
                                <field name="email" placeholder="Ex. abc@mail.com"
                                       readonly="state not in ['draft', 'approved']"/>
                                <field name="phone" placeholder="Ex. 123456789"
                                       readonly="state not in ['draft', 'approved']"/>
                                <field name="gender" placeholder="Ex. Male" readonly="state != 'draft'"/>
                                <field name="dob" placeholder="Date of Birth"
                                       readonly="state not in ['draft', 'approved']"/>
                                <field name="age" placeholder="Age" readonly="1"/>
                                <span class="fw-bold">Address</span>
                                <div class="o_address_format">
                                    <field name="street" placeholder="Street..." class="o_address_street"
                                           readonly="state not in ['draft', 'approved']"/>
                                    <field name="street2" placeholder="Street2..." class="o_address_street"
                                           readonly="state not in ['draft', 'approved']"/>
                                    <field name="zip" placeholder="ZIP" class="o_address_zip"
                                           readonly="state not in ['draft', 'approved']"/>
                                    <field name="city" placeholder="City" class="o_address_city"
                                           readonly="state not in ['draft', 'approved']"/>
                                    <field name="state_id" placeholder="State" class="o_address_state"
                                           readonly="state not in ['draft', 'approved']"/>
                                    <field name="country_id" placeholder="Country" class="o_address_country"
                                           readonly="state not in ['draft', 'approved']"/>
                                </div>
                            </group>
                            <group string="Academic Information">
                                <field name="enrollment_no" placeholder="Number" readonly="1" class="fw-bold fs-10"/>
                                <field name="current_date" string="Admission Date" readonly="1"/>
                                <field name="hobby_ids" placeholder="Your Hobby" widget="many2many_tags"
                                       readonly="state not in ['draft', 'approved']"/>
                                <field name="standard_id" placeholder="Standard"
                                       readonly="state not in ['draft', 'approved']"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="admission_list" model="ir.ui.view">
            <field name="name">admission.list</field>
            <field name="model">admission</field>
            <field name="arch" type="xml">
                <list>
                    <field name="admission_sequence" placeholder="Your Name" string="Number" class="fw-bold fs-10"/>
                    <field name="current_date" string="Admission Date" width="120"/>
                    <field name="user_id" string="Name" class="fw-bold fs-10"/>
                    <field name="enrollment_no" string="Enroll No" class="fw-bold fs-10"/>
                    <field name="phone" string="Mobile"/>
                    <field name="email" string="Mail"/>
                    <field name="standard_id" string="Standard"/>
                    <field name="state" string="Status" widget="badge" decoration-info="state == 'confirmed'"
                       decoration-success="state == 'in_admission'" decoration-danger="state == 'terminate'"/>
                    <field name="city"/>
                    <field name="state_id" string="State"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="admission_search_view" model="ir.ui.view">
            <field name="name">admission.search</field>
            <field name="model">admission</field>
            <field name="arch" type="xml">
                <search>
                    <field name="user_id"/>
                    <field name="age"/>
                    <field name="dob"/>
                    <field name="standard_id"/>
                    <filter string="Class 1" name="running_contract" domain="[('standard_id', '=', '1st')]"/>
                    <filter string="Class 2" name="running_contract" domain="[('standard_id', '=', '2nd')]"/>
                    <filter string="Class 3" name="running_contract" domain="[('standard_id', '=', '3rd')]"/>
                    <filter string="Class 4" name="running_contract" domain="[('standard_id', '=', '4th')]"/>
                    <filter string="Class 5" name="running_contract" domain="[('standard_id', '=', '5th')]"/>
                    <filter string="Class 6" name="running_contract" domain="[('standard_id', '=', '6th')]"/>
                    <filter string="Class 7" name="running_contract" domain="[('standard_id', '=', '7th')]"/>
                    <filter string="Class 8" name="running_contract" domain="[('standard_id', '=', '8th')]"/>
                    <filter string="Class 9" name="running_contract" domain="[('standard_id', '=', '9th')]"/>
                    <filter string="Class 10" name="running_contract" domain="[('standard_id', '=', '10th')]"/>
                </search>
            </field>
        </record>

        <!--    Kanban View-->
        <record id="admission_kanban_view" model="ir.ui.view">
            <field name="name">admission.kanban.view</field>
            <field name="model">admission</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <templates>
                        <t t-name="card">
                            <div class="row mb4">
                                <div class="mb-1">
                                    <strong>Name:&amp;nbsp;</strong>
                                    <field name="user_id"/>
                                </div>
                                <div>
                                    <strong>Email:&amp;nbsp;</strong>
                                    <field name="email"/>
                                </div>
                                <div>
                                    <strong>Phone:&amp;nbsp;</strong>
                                    <field name="phone"/>
                                </div>
                                <div>
                                    <strong>DOB:&amp;nbsp;</strong>
                                    <field class="fw-bold fs-7" name="dob"/>
                                </div>
                                <div>
                                    <strong>Standard:&amp;nbsp;</strong>
                                    <field class="fw-bold fs-7" name="standard_id"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Action -->
        <record id="admission_action" model="ir.actions.act_window">
            <field name="name">Admission</field>
            <field name="res_model">admission</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create first Admission!
                </p>
            </field>
        </record>

        <record id="server_action_admission_to_draft" model="ir.actions.server">
            <field name="name">Set Admission To Draft</field>
            <field name="model_id" ref="model_admission"/>
            <field name="binding_model_id" ref="model_admission"/>
            <field name="state">code</field>
            <field name="code">action = records.set_to_draft_server_action()</field>
        </record>

    </data>
</odoo>