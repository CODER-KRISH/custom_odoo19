<?xml version="1.0" encoding="UTF-8"?>

<odoo>


    <!-- ========================================================= -->
    <!-- Groups for Sales Module -->
    <!-- ========================================================= -->

    <!--    Module Category -->
    <record id="module_category_sale_order" model="ir.module.category">
        <field name="name">Custom Sales</field>
    </record>

    <!--    Privilege Ids -->
    <record id="res_groups_sale_mgt" model="res.groups.privilege">
        <field name="name">Custom Sales</field>
        <field name="category_id" ref="module_category_sale_order"/>
    </record>


    <!-- Groups -->


    <!-- Groups of Manager -->
    <record id="group_sale_manager" model="res.groups">
        <field name="name">Sale Manager</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_sale_mgt"/>
    </record>

    <!-- Groups of Boss -->
    <record id="group_sale_boss" model="res.groups">
        <field name="name">Sale Boss</field>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_sale_manager'))]"/>
        <field name="privilege_id" ref="res_groups_sale_mgt"/>
    </record>


    <!-- ========================================================= -->
    <!-- Groups for Stock Picking Module -->
    <!-- ========================================================= -->

    <!-- Module Category -->
    <record id="module_category_stock_picking" model="ir.module.category">
        <field name="name">Delivery</field>
    </record>

    <!-- Privilege Ids -->
    <record id="res_groups_stock_picking" model="res.groups.privilege">
        <field name="name">Delivery</field>
        <field name="category_id" ref="module_category_stock_picking"/>
    </record>

    <!-- Groups -->

    <!-- Groups of Delivery Manager -->
    <record id="group_delivery_manager" model="res.groups">
        <field name="name">Delivery Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_stock_picking"/>
    </record>

</odoo>