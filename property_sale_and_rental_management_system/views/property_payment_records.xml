<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="property_payment_records_form_view" model="ir.ui.view">
        <field name="name">property.payment.records.form.view</field>
        <field name="model">property.payment.records</field>
        <field name="arch" type="xml">
            <form create="False">
                <sheet>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="property_id" readonly="1"/>
                            <field name="property_type" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="offer_price" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="owner_id" readonly="1" string="Seller/Owner"/>
                            <field name="buyer_id" readonly="1" string="Buyer/Tenant"/>
                            <field name="payment_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="property_payment_records_list_view" model="ir.ui.view">
        <field name="name">property.payment.records.list.view</field>
        <field name="model">property.payment.records</field>
        <field name="arch" type="xml">
            <list create="False">
                <field name="name" class="fs-10 fw-bold" string="Invoice No"/>
                <field name="payment_date" width="150"/>
                <field name="property_id" class="fs-10 fw-bold"/>
                <field name="property_type" class="fs-10 fw-bold"/>
                <field name="owner_id" string="Seller/Owner"/>
                <field name="buyer_id" string="Buyer/Tenant" class="fs-10 fw-bold"/>
                <field name="currency_id" nolabel="1" invisible="1"/>
                <field name="offer_price" widget="monetary" string="Amount" class="fs-10 fw-bold"/>
            </list>
        </field>
    </record>

    <record id="view_order_tree_inherit_total" model="ir.ui.view">
        <field name="name">sale.order.tree.total</field>
        <field name="model">property.payment.records</field>
        <field name="inherit_id" ref="property_sale_and_rental_management_system.property_payment_records_list_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='offer_price']" position="attributes">
                <attribute name="sum">Total</attribute>
            </xpath>
        </field>
    </record>

    <record id="search_sale_rent_payments_view" model="ir.ui.view">
        <field name="name">property.payment.records.search.view</field>
        <field name="model">property.payment.records</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Sale Payments" name="property_type" domain="[('property_type', '=', 'sale')]"/>
                <filter string="Rent Payments" name="property_type" domain="[('property_type', '=', 'rent')]"/>
            </search>
        </field>
    </record>

    <record id="action_property_payment_records" model="ir.actions.act_window">
        <field name="name">Payment Records</field>
        <field name="res_model">property.payment.records</field>
        <field name="view_mode">list,form,search</field>
    </record>

</odoo>