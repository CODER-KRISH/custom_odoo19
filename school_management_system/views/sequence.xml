<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <!-- Sequence for admission Sequence -->
        <record id="seq_admission" model="ir.sequence">
            <field name="name">Admission Sequence</field>
            <field name="code">admission</field>
            <field name="prefix">ADM</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Fee Payment Records -->
        <record id="seq_student_fees_payment" model="ir.sequence">
            <field name="name">Student Fees Sequence</field>
            <field name="code">student.fees.payment</field>
            <field name="prefix">FEE/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for enrollment Sequence -->
        <record id="seq_enrollment" model="ir.sequence">
            <field name="name">Enrollment Sequence</field>
            <field name="code">enrollment</field>
            <field name="prefix">ENR</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Exam -->
        <record id="seq_student_exams" model="ir.sequence">
            <field name="name">Student Exams Sequence</field>
            <field name="code">exam</field>
            <field name="prefix">EXAM/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for student Exam -->
        <record id="seq_student_result" model="ir.sequence">
            <field name="name">Student Result Sequence</field>
            <field name="code">student.exam</field>
            <field name="prefix">SR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Announcement Model -->
        <record id="seq_announcement" model="ir.sequence">
            <field name="name">Announcement Sequence</field>
            <field name="code">announcement</field>
            <field name="prefix">ANN/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Timetable Model -->
        <record id="seq_timetable" model="ir.sequence">
            <field name="name">Timetable Sequence</field>
            <field name="code">timetable</field>
            <field name="prefix">TT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
