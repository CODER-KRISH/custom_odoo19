<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="module_category_property" model="ir.module.category">
        <field name="name">Property</field>
    </record>

    <record id="res_groups_property_mgt" model="res.groups.privilege">
        <field name="name">Property</field>
        <field name="category_id" ref="module_category_property"/>
    </record>

    <record id="group_property_mgt_user" model="res.groups">
        <field name="name">Property User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_property_mgt"/>
    </record>

    <record id="group_property_mgt_admin" model="res.groups">
        <field name="name">Property Admin</field>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_property_mgt_user'))]"/>
        <field name="privilege_id" ref="res_groups_property_mgt"/>
    </record>

</odoo>