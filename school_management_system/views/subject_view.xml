<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Form View-->
    <record id="subject_form_view" model="ir.ui.view">
        <field name="name">subject.form.view</field>
        <field name="model">subject</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="confirm_subject" string="Confirm" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="back_to_draft" string="To Draft" type="object" class="btn-secondary"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Subject name" readonly="state != 'draft'"/>
                            <field name="standard_id" string="Standard" readonly="state != 'draft'"/>
                            <field name="teacher_ids" string="Teachers" widget="many2many_tags"
                                   domain="[('standard_id', '=', standard_id)]" readonly="state != 'draft'"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    List View-->
    <record id="subject_list" model="ir.ui.view">
        <field name="name">subject.list.view</field>
        <field name="model">subject</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Subjects"/>
                <field name="standard_id" string="Standard"/>
                <field name="teacher_ids" string="Teachers" widget="many2many_tags"/>
                <field name="state" string="Status" widget="badge"/>
            </list>
        </field>
    </record>

    <!--    Kanban View-->
    <record id="subject_kanban_view" model="ir.ui.view">
        <field name="name">subject.kanban.view</field>
        <field name="model">subject</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div class="row mb4">
                            <div>
                                <span>Name:&amp;nbsp;</span>
                                <field name="name"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!--    Action-->
    <record id="subject_action" model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">subject</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new Subject!
            </p>
        </field>
    </record>

    <record id="server_action_active_to_draft" model="ir.actions.server">
        <field name="name">Set Subject To Draft</field>
        <field name="model_id" ref="model_subject"/>
        <field name="binding_model_id" ref="model_subject"/>
        <field name="state">code</field>
        <field name="code">action = records.back_to_draft()</field>
    </record>

    <record id="server_action_draft_to_active" model="ir.actions.server">
        <field name="name">Set Subject To Active</field>
        <field name="model_id" ref="model_subject"/>
        <field name="binding_model_id" ref="model_subject"/>
        <field name="state">code</field>
        <field name="code">action = records.confirm_subject()</field>
    </record>

</odoo>