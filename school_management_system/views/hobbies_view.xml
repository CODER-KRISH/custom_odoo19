<?xml version="1.0" encoding="utf-8" ?>

<odoo>
    <!--    Form View-->
    <record id="hobbies_form_view" model="ir.ui.view">
        <field name="name">hobby.form.view</field>
        <field name="model">hobby</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="hobbies_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    List View-->
    <record id="hobby_list" model="ir.ui.view">
        <field name="name">hobby.list.view</field>
        <field name="model">hobby</field>
        <field name="arch" type="xml">
            <list>
                <field name="hobbies_name"/>
                <field name="student_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>
    <!--    Kanban View-->
    <record id="hobby_kanban_view" model="ir.ui.view">
        <field name="name">hobby.kanban.view</field>
        <field name="model">hobby</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div class="row mb4">
                            <div>
                                <span>Hobby:&amp;nbsp;</span>
                                <field name="hobbies_name"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!--    Action-->
    <record id="hobbies_action" model="ir.actions.act_window">
        <field name="name">Hobby</field>
        <field name="res_model">hobby</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

</odoo>