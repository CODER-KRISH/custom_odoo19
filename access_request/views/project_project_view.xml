<odoo>

    <record id="view_project_form_inherit" model="ir.ui.view">
        <field name="name">view.project.form.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//form/sheet/group/group[2]/field[@name='user_id']" position="after">
                <field name="approver_ids" widget="many2many_avatar_user" string="Approvers"/>
            </xpath>

            <xpath expr="//form/sheet/div[@name='button_box']/button[@name='action_view_tasks']" position="after">
                <button name="action_open_access_requests" type="object"
                        class="oe_stat_button" icon="fa-shield">
                    <field string="Access Requests" name="access_request_count" widget="statinfo"/>
                </button>
                <button name="action_open_access_register" type="object" class="oe_stat_button" icon="fa-address-book">
                    <field string="Access Register" name="access_register_count" widget="statinfo"/>
                </button>
            </xpath>

        </field>
    </record>

</odoo>