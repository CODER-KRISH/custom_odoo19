<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="form_student_exam_view" model="ir.ui.view">
        <field name="name">form.student.exam.view</field>
        <field name="model">student.exam</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Confirm"
                            name="action_complete_and_declare_result"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_print_result_report"
                            string="Print"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <button string="Reset to Draft"
                            name="action_reset_draft"
                            type="object"
                            groups="!school_management_system.group_school_student"
                            invisible="state == 'draft'"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <h1>
                        <field name="sequence_no" string="Sequence No." class="fw-bold" readonly="1"/>
                    </h1>
                    <group>
                        <group string="Student Details">
                            <field name="standard_id" readonly="state != 'draft'"/>
                            <field name="student_id" domain="[('standard_id', '=', standard_id)]"
                                   readonly="state != 'draft'"/>
                            <field name="enrollment_no" readonly="1"/>
                        </group>
                        <group string="Exam Details">
                            <field name="exam_id"
                                   domain="[('standard_id', '=', standard_id)]" readonly="state != 'draft'"/>
                            <field name="academic_year"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Subject Marks">
                            <field name="line_ids"
                                   readonly="state == 'done'">
                                <list editable="bottom">
                                    <field name="subject_id" readonly="1" force_save="1"/>
                                    <field name="passing_marks" readonly="1" width="140"/>
                                    <field name="max_marks" readonly="1" force_save="1" width="140"/>
                                    <field name="obtained_marks" width="140"/>
                                    <field name="subject_percentage" readonly="1" string="Percentage"
                                           widget="percentage"
                                           options="{'max_value': 100, 'editable': false}" width="100"/>
                                    <field name="subject_grade" readonly="1" width="100" class="fw-bold"/>
                                    <field name="pass_or_fail" readonly="1" string="Pass / Fail"
                                           widget="badge"
                                           decoration-success="pass_or_fail == 'pass'"
                                           decoration-danger="pass_or_fail == 'fail'"/>

                                </list>
                            </field>

                            <div class="oe_subtotal_footer oe_right">

                                <div style="display: flex; justify-content: flex-end; font-size: 16px;">
                                    <span style="margin-right: 10px; font-weight: bold">Total Marks:</span>
                                    <field name="total_marks" readonly="1" style="font-weight: bold;"/>
                                </div>
                                <div style="display: flex; justify-content: flex-end; font-size: 16px;">
                                    <span style="margin-right: 10px; font-weight: bold">Marks Obtained:</span>
                                    <field name="total_obtained_marks" readonly="1" style="font-weight: bold;"/>
                                </div>
                                <div style="display: flex; justify-content: flex-end; font-size: 16px;">
                                    <span style="margin-right: 10px; font-weight: bold">Percentage:</span>
                                    <field name="percentage" widget="percentage" readonly="1"
                                           style="font-weight: bold;"/>
                                </div>
                                <div style="display: flex; justify-content: flex-end; font-size: 16px;">
                                    <span style="margin-right: 10px; font-weight: bold">Grade:</span>
                                    <field name="grade" readonly="1" style="font-weight: bold;"/>
                                </div>
                                <div style="display: flex; justify-content: flex-end; font-size: 16px;"
                                     invisible="state != 'done'">
                                    <span style="margin-right: 10px; font-weight: bold">Result:</span>
                                    <field name="result" readonly="1" style="font-weight: bold;"/>
                                </div>
                            </div>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="list_student_exam_view" model="ir.ui.view">
        <field name="name">list.student.exam.view</field>
        <field name="model">student.exam</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence_no" string="Sequence No." class="fw-bold"/>
                <field name="student_id" string="Student"/>
                <field name="enrollment_no" readonly="1" string="Enrollment No" class="fw-bold"/>
                <field name="standard_id" string="Standard"/>
                <field name="exam_id" string="Exam" class="fw-bold"/>
                <field name="academic_year"/>
                <field name="total_marks" string="Total Marks" width="90" class="fw-bold"/>
                <field name="total_obtained_marks" string="Obtained Marks" width="130" class="fw-bold"/>
                <field name="percentage" string="Percentage" widget="percentage" class="fw-bold"/>
                <field name="grade" string="Grade" class="fw-bold"/>
                <field name="result" widget="badge"
                       decoration-success="result == 'pass'"
                       decoration-danger="result == 'fail'"
                       decoration-warning="result == 'not_declared'"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'done'" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_student_exam" model="ir.actions.act_window">
        <field name="name">Student Exam Results</field>
        <field name="res_model">student.exam</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Student Exam Result!
            </p>
        </field>
    </record>

</odoo>