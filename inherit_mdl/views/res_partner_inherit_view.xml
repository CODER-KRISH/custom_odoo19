<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="res_partner_inherit_form_view" model="ir.ui.view">
        <field name="name">res.partner.inherit.form.view</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group/field[@name='parent_id']" position="after">
                <field name="is_delivery_address"/>
                <field name="w_type"/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_inherit_form_credit_limit_view" model="ir.ui.view">
        <field name="name">res.partner.inherit.form.credit.limit.view</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='credit_limits']/div" position="after">
                <field name="used_cr_limit" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="not use_partner_credit_limit"/>
                <field name="left_cr_limit" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="not use_partner_credit_limit"/>
            </xpath>
        </field>
    </record>
</odoo>