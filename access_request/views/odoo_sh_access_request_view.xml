<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_odoo_sh_access_request_form" model="ir.ui.view">
        <field name="name">view.odoo.sh.access.request.form</field>
        <field name="model">odoo.sh.access.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                    />

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'submitted' or not is_current_user_approver"
                    />

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'submitted' or not is_current_user_approver"
                    />

                    <button name="action_revoke"
                            string="Revoke"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'approved' or not is_current_user_approver"
                    />

                    <button name="action_set_to_draft"
                            string="Reset to Draft"
                            type="object"
                            class="btn-secondary"
                            invisible="state in ['draft', 'revoked'] or not is_current_user_approver"
                    />

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,approved"
                           invisible="state == 'rejected' or state == 'revoked'"
                    />
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,approved,revoked"
                           invisible="state != 'revoked'"
                    />
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,rejected"
                           invisible="state != 'rejected'"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <!-- Request Details -->
                        <group string="Request Details">
                            <field name="project_id" readonly="state != 'draft'" required="1"/>
                            <field name="task_id"
                                   readonly="state != 'draft'"
                                   domain="[('project_id', '=', project_id)]" required="1"/>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="github_username" readonly="1"/>
                        </group>

                        <!-- Access Details -->
                        <group string="Access Details">
                            <field name="access_type" readonly="state != 'draft'" required="1"/>
                            <field name="environment"
                                   readonly="state != 'draft'"
                                   invisible="access_type != 'odoo_sh'"/>
                            <field name="role" readonly="state != 'draft'" required="1"/>
                            <field name="access_token" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <!-- Approval Details -->
                        <group string="Approval Details">
                            <field name="approver_ids"
                                   widget="many2many_avatar_user"
                                   readonly="1"/>

                            <field name="approved_by_id"
                                   readonly="1"
                                   invisible="state not in ['approved', 'revoked']"/>

                            <field name="rejected_by_id"
                                   readonly="1"
                                   invisible="state != 'rejected'"/>

                            <field name="processed_time"
                                   readonly="1"
                                   string="Time"
                                   invisible="state not in ['rejected', 'approved', 'revoked']"/>

                            <field name="rejection_reason" readonly="1" invisible="state != 'rejected'"/>
                        </group>

                        <!-- Validity Period -->
                        <group string="Validity Period">
                            <field name="start_date"
                                   string="Access Period"
                                   widget="daterange"
                                   readonly="state != 'draft'"
                                   options="{'end_date_field': 'end_date', 'always_range': true}" required="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_odoo_sh_access_request_list" model="ir.ui.view">
        <field name="name">view.odoo.sh.access.request.list</field>
        <field name="model">odoo.sh.access.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" class="fw-bold"/>
                <field name="project_id" width="150"/>
                <field name="task_id" width="150"/>
                <field name="access_type" string="Access Request" class="fw-bold"/>
                <field name="user_id" string="Requester" class="fw-bold"/>
                <field name="github_username" string="Github"/>
                <field name="approved_by_id" string="Approved By" width="100" class="fw-bold"/>
                <field name="rejected_by_id" string="Rejected By" width="100" class="fw-bold"/>
                <field name="processed_time" string="Time"/>
                <field name="state" widget="badge" string="Status" decoration-info="state == 'submitted'"
                       decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"
                       decoration-muted="state == 'revoked'"/>
            </list>
        </field>
    </record>

    <record id="action_odoo_sh_ar" model="ir.actions.act_window">
        <field name="name">All Requests</field>
        <field name="res_model">odoo.sh.access.request</field>
        <field name="view_mode">list,form,search</field>
    </record>

    <record id="action_odoo_access_register" model="ir.actions.act_window">
        <field name="name">Approved Requests</field>
        <field name="res_model">odoo.sh.access.request</field>
        <field name="domain">[('state', '=', 'approved')]</field>
        <field name="context">{'create': 0}</field>
        <field name="view_mode">list,form,search</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Template found
            </p>
            <p>
                Let's create one
            </p>
        </field>
    </record>

    <record id="action_odoo_revoked_access" model="ir.actions.act_window">
        <field name="name">Revoked Requests</field>
        <field name="res_model">odoo.sh.access.request</field>
        <field name="domain">[('state', '=', 'revoked')]</field>
        <field name="context">{'create': 0}</field>
        <field name="view_mode">list,form,search</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Template found
            </p>
            <p>
                No Revoked Access Found!
            </p>
        </field>
    </record>

</odoo>