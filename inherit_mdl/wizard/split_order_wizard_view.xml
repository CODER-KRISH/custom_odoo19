<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="act_split_order" model="ir.actions.act_window">
        <field name="name">Split Sale Order</field>
        <field name="res_model">split.order</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_split_order_form" model="ir.ui.view">
        <field name="name">Split Order Lines</field>
        <field name="model">split.order</field>
        <field name="arch" type="xml">
            <form>
                <field name="order_line_ids">
                    <list editable="bottom">
                        <field name="product_template_id" readonly="1" force_save="1"/>
                        <field name="product_id" column_invisible="1" readonly="1" force_save="1"/>
                        <field name="qty"/>
                    </list>
                </field>
                <footer>
                    <button name="action_split_order" string="Split Order" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>