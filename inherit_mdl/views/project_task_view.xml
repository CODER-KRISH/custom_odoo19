<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="view_project_task_inherit_form" model="ir.ui.view">
        <field name="name">view.project.task.inherit.form</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group[1]/field[@name='user_ids']" position="after">
                <field name="ticket_type" string="Ticket Type"/>
                <field name="product_id" string="Appliance"/>
                <field name="brand" string="Brand"/>
                <field name="serial_number" string="Serial No."/>
                <field name="check_issue" string="Issue" invisible="ticket_type != 'repair'"/>
            </xpath>

            <!-- ========================================== -->
            <!-- xpath for auto create task when SO Confirm -->
            <!-- ========================================== -->
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="start_date"
                       string="Time Period"
                       widget="daterange"
                       options="{'end_date_field': 'end_date', 'always_range': true}"/>
                <field name="so_line_id" readonly="1" invisible="not so_line_id" string="SO Line"/>
            </xpath>
        </field>
    </record>

</odoo>