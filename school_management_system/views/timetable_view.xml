<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── MONDAY list view (standalone, used inside form via One2many) ── -->
    <record id="view_timetable_monday_list" model="ir.ui.view">
        <field name="name">timetable.monday.list</field>
        <field name="model">timetable.monday</field>
        <field name="arch" type="xml">
            <list editable="bottom"
                  decoration-info="period_type == 'break'"
                  decoration-warning="period_type == 'practical'">

                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="duration" widget="float_time" optional="show"/>
                <field name="period_type"/>
                <field name="room" optional="hide"/>
                <field name="notes" optional="show"/>
            </list>
        </field>
    </record>

