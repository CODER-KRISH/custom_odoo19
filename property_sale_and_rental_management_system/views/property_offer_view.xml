<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <record id="property_offer_form_view" model="ir.ui.view">
        <field name="name">property.offer.form.view</field>
        <field name="model">property.offer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept_offer" string="Accept Offer" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel_offer" string="Cancel" type="object"
                            invisible="state in ['cancelled', 'rejected', 'closed']"
                            class="btn-secondary" confirm="Are you sure you want to cancel?"/>

                    <!--statusbar-->
                    <field name="state" widget="statusbar"
                           invisible="state not in ['draft', 'interested', 'accepted']"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,interested,accepted,cancelled"
                           invisible="state != 'cancelled'"
                    />
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,interested,accepted,closed"
                           invisible="state != 'closed'"
                    />
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,interested,rejected"
                           invisible="state != 'rejected'"
                    />

                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="property_type" readonly="state != 'draft'"/>
                            <field name="property_id" placeholder="Enter Property Name" readonly="state != 'draft'"
                                   domain="['|', ('state', '=', 'available'), ('state', '=', 'deal_received'), ('property_type', '=', property_type)]"/>
                            <strong>Property Address</strong>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." readonly="1"/>
                                <field name="street2" placeholder="Street2..." class="o_address_street"
                                       readonly="1"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="1"/>
                                <field name="city" placeholder="City" class="o_address_city"
                                       readonly="1"/>
                                <field name="state_id" placeholder="State" class="o_address_state"
                                       readonly="1"/>
                                <field name="country_id" placeholder="Country" class="o_address_country"
                                       readonly="1"/>
                            </div>
                        </group>
                        <group>
                            <field name="offer_date" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="price" widget="monetary" readonly="1"
                                   class="fw-bold"/>
                            <field name="owner_id" placeholder="Owner" readonly="1" invisible="state == 'closed'"/>
                            <field name="original_owner_id" readonly="1" invisible="state != 'closed'"/>
                            <field name="buyer_id" invisible="property_type != 'sale'" readonly="state != 'draft'"/>
                            <field name="tenant_id" invisible="property_type != 'rent'" readonly="state != 'draft'"/>
                            <field name="your_price" readonly="state != 'draft'" class="fw-bold"/>
                            <field name="reject_reason" readonly="1" class="fw-bold" invisible="state not in ['rejected', 'cancelled']"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="property_offer_list_view" model="ir.ui.view">
        <field name="name">property.offer.list.view</field>
        <field name="model">property.offer</field>
        <field name="arch" type="xml">
            <list>
                <field name="property_id"/>
                <field name="currency_id" nolabel="1" invisible="1" width="5"/>
                <field name="price" widget="monetary" class="fw-bold"/>
                <field name="property_type" class="fs-10 fw-bold"/>
                <field name="original_owner_id" string="Owner/Seller"/>
                <field name="partner_id" string="Buyer/Tenant"/>
                <field name="your_price" string="Customer Price" widget="monetary" class="fw-bold"/>
                <field name="state" widget="badge" string="Status" decoration-info="state == 'interested'"
                       decoration-success="state == 'closed'" decoration-primary="state == 'accepted'"
                       decoration-danger="state == 'cancelled' or state == 'rejected'"/>
                <field name="offer_date"/>
            </list>
        </field>
    </record>

    <record id="search_property_offer_view" model="ir.ui.view">
        <field name="name">search.property.offer.view</field>
        <field name="model">property.offer</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Closed Offers" name="property_type" domain="[('state', '=', 'closed')]"/>
                <filter string="Rejected Offers" name="property_type" domain="[('state', '=', 'rejected')]"/>
                <filter name="state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_property_offer_set_draft" model="ir.actions.server">
        <field name="name">Set Property Offer Draft</field>
        <field name="model_id" ref="model_property_offer"/>
        <field name="binding_model_id" ref="model_property_offer"/>
        <field name="state">code</field>
        <field name="code">action = records.property_offer_state_to_draft_server_action()</field>
    </record>

    <record id="action_property_offer" model="ir.actions.act_window">
        <field name="name">Offers</field>
        <field name="res_model">property.offer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>