<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="reject_reasons_form_view" model="ir.ui.view">
        <field name="name">reject.reasons.form.view</field>
        <field name="model">reject.reasons</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name" string="Reason"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="reject_reasons_list_view" model="ir.ui.view">
        <field name="name">reject.reasons.list.view</field>
        <field name="model">reject.reasons</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Reasons"/>
            </list>
        </field>
    </record>

    <record id="action_reject_reasons" model="ir.actions.act_window">
        <field name="name">Reasons</field>
        <field name="res_model">reject.reasons</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>