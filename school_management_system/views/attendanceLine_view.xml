<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="attendance_line_list_view" model="ir.ui.view">
        <field name="name">attendance.line.list.view</field>
        <field name="model">attendance.line</field>
        <field name="arch" type="xml">
            <list create="False">
                <field name="student_id" string="Student" width="100"/>
                <field name="date" string="Date" width="100"/>
                <field name="standard_id" string="Standard" width="100"/>
                <field name="p_or_a" string="Present" width="100"/>
            </list>
        </field>
    </record>

    <record id="attendance_line_calendar_view" model="ir.ui.view">
        <field name="name">attendance.line.calendar.view</field>
        <field name="model">attendance.line</field>
        <field name="arch" type="xml">
            <calendar string="Attendance Calendar"
                      date_start="date">

                <field name="student_id"/>
                <field name="date"/>

            </calendar>
        </field>
    </record>

    <record id="search_attendance_line_view" model="ir.ui.view">
        <field name="name">search.attendance.line.view</field>
        <field name="model">attendance.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="date"/>

                <filter string="Today"
                        name="main_filter"
                        domain="[('date', '=', context_today())]"/>
            </search>
        </field>
    </record>

    <record id="attendance_line_action" model="ir.actions.act_window">
        <field name="name">Students Attendances</field>
        <field name="res_model">attendance.line</field>
        <field name="view_mode">list,calendar</field>
        <field name="context">
            {
            'search_default_main_filter': 1
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Attendance not found!
            </p>
        </field>
    </record>

</odoo>