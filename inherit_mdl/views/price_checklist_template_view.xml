<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="view_price_checklist_template_form" model="ir.ui.view">
        <field name="name">view.price.checklist.template.form</field>
        <field name="model">price.checklist.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="checklist_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_price_checklist_template_list" model="ir.ui.view">
        <field name="name">view.price.checklist.template.list</field>
        <field name="model">price.checklist.template</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="checklist_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

<!--    <record id="view_price_checklist_calander" model="ir.ui.view">-->
