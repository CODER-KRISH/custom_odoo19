    <!-- List View -->
    <record id="standard_list" model="ir.ui.view">
        <field name="name">standard.list.view</field>
        <field name="model">standard</field>
        <field name="arch" type="xml">
            <list>
                <field name="class_name" string="Class Name"/>
                <field name="subject_ids" string="Subjects" widget="many2many_tags"/>
                <field name="student_ids" string="Students" widget="many2many_tags"/>
            </list>
        </field>
    </record>

