<!--            <calendar string="Calendar" date_start="date_begin">-->
<!--                <field name="name"/>-->
<!--                <field name="checklist_ids" widget="many2many_tags"/>-->
<!--            </calendar>-->
<!--        </field>-->
<!--    </record>-->

    <record id="action_price_checklist_template" model="ir.actions.act_window">
        <field name="name">Price Check List Template</field>
        <field name="res_model">price.checklist.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Your First Checklist Template!
            </p>
        </field>
    </record>

</odoo>