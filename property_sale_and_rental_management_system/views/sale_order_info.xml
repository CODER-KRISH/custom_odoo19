<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="sale_order_info_from_view" model="ir.ui.view">
        <field name="name">sale.order.info.form.view</field>
        <field name="model">sale.order.info</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sale_order_info_list_view" model="ir.ui.view">
        <field name="name">sale.order.info.list.view</field>
        <field name="model">sale.order.info</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_sale_order_info" model="ir.actions.act_window">
        <field name="name">Sale Order Info</field>
        <field name="res_model">sale.order.info</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sales_config"
              sequence="30"
              name="Sales Orders Info"
              parent="sale.menu_sale_config">

        <menuitem id="sale_order_info_menu"
                  name="Sale Order Info"
                  action="action_sale_order_info"
                  sequence="10"/>

    </menuitem>


</odoo>