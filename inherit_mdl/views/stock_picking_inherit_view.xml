<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="form_stock_picking_inherit_view" model="ir.ui.view">
        <field name="name">form.stock.picking.inherit.view</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_id']" position="after">
                <field name="block_delivery" readonly="1" groups="!inherit_mdl.group_delivery_manager"/>
                <field name="block_delivery" groups="inherit_mdl.group_delivery_manager" />
            </xpath>
        </field>
    </record>

</odoo>