<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- Module Category -->
    <record id="module_category_subscription" model="ir.module.category">
        <field name="name">Subscription Management</field>
    </record>

    <!-- Privilege Ids -->
    <record id="res_groups_subs" model="res.groups.privilege">
        <field name="name">Subscription Management</field>
        <field name="category_id" ref="module_category_subscription"/>
    </record>

    <!-- Groups -->

    <!-- User Group -->
    <record id="group_subs_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">1</field>
        <field name="privilege_id" ref="res_groups_subs"/>
    </record>

    <!-- Admin as Manager Group -->
    <record id="group_subs_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="sequence">2</field>
        <field name="privilege_id" ref="res_groups_subs"/>
        <field name="implied_ids" eval="[(4, ref('group_subs_user'))]"/>
    </record>

    <record id="subscription_order_user_rule" model="ir.rule">
        <field name="name">Subscription - Own Records</field>
        <field name="model_id" ref="model_subscription_order"/>
        <field name="domain_force">
            ['|', ('account_manager_id', '=', user.partner_id.id), ('partner_id', '=', user.partner_id.id)]
        </field>
    </record>

    <record id="subscription_order_manager_rule" model="ir.rule">
        <field name="name">Subscription - Manager All Records</field>
        <field name="model_id" ref="model_subscription_order"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>

</odoo> 