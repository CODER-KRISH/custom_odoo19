<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="property_sale_deal_form_view" model="ir.ui.view">
        <field name="name">property.sale.deal.form.view</field>
        <field name="model">property.sale.deal</field>
        <field name="arch" type="xml">
            <form create="false">
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="action_payment" type="object" class="btn-primary" string="Pay Agreement"
                            invisible="state in ['paid']"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>

                    <!-- Ribbon -->
                    <widget name="web_ribbon"
                            title="PAID"
                            bg_color="bg-success"
                            invisible="state not in 'paid'"/>
                    <h1>
                        <field name="property_id" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="agreement_date" readonly="1"/>
                            <span>Property Address</span>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..."/>
                                <field name="street2" placeholder="Street2..." class="o_address_street"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" placeholder="State" class="o_address_state"/>
                                <field name="country_id" placeholder="Country" class="o_address_country"/>
                            </div>
                        </group>
                        <group>
                            <field name="payment_date" readonly="1"/>
                            <field name="payment_reference" readonly="1" string="Invoice No"/>
                            <field name="owner_id" readonly="1"/>
                            <field name="buyer_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="price" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="property_sale_deal_list_view" model="ir.ui.view">
        <field name="name">property.sale.deal.list.view</field>
        <field name="model">property.sale.deal</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="property_id" />
                <field name="owner_id" string="Seller" width="150"/>
                <field name="buyer_id" string="Buyer" width="100"/>
                <field name="currency_id" nolabel="1" invisible="1"/>
                <field name="agreement_date" width="150"/>
                <field name="payment_date" width="150" />
                <field name="payment_reference" width="150" string="Invoice No" class="fs-10 fw-bold"/>
                <field name="price" widget="monetary" string="Amount" class="fs-10 fw-bold" width="100"/>
                <field name="state" string="Status" widget="badge" decoration-warning="state == 'payment_due'"
                       decoration-success="state == 'paid'" />
            </list>
        </field>
    </record>

    <record id="search_property_sale_deal_view" model="ir.ui.view">
        <field name="name">search.property.sale.deal.view</field>
        <field name="model">property.sale.deal</field>
        <field name="arch" type="xml">
            <search>
                <filter name="state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_property_sale_deal" model="ir.actions.act_window">
        <field name="name">Sale Agreements</field>
        <field name="res_model">property.sale.deal</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>