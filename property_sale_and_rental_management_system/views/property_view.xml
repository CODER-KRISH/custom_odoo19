<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--Property Form View-->
    <record id="property_form_view" model="ir.ui.view">
        <field name="name">property.form.view</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Button to Publish Property-->
                    <button name="add_property"
                            string="Publish Property"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                    />

                    <!-- Button to Accept deals-->
                    <button name="accept_deal"
                            string="Accept" type="object"
                            class="btn-primary"
                            invisible="state != 'deal_received'"
                    />

                    <!-- Button to Create Sale Agreement-->
                    <button name="action_create_sale_deal"
                            string="Create Agreement"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['offer_confirmed', 'deal_confirmed'] or property_type not in ['sale']"
                    />

                    <!-- Button to Create Rent Agreement-->
                    <button name="action_create_rent_deal"
                            string="Create Contract"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['offer_confirmed', 'deal_confirmed'] or property_type not in ['rent']"
                    />

                    <!-- Button to view Sale Agreement-->
                    <button name="action_view_sale_deal"
                            string="Go to Sale Agreement"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['agreement_pending'] or property_type not in ['sale']"
                    />

                    <!-- Button to view Rent Agreement-->
                    <button name="action_view_rent_deal"
                            string="Go to Rent Contract"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['contract_pending'] or property_type not in ['rent']"
                    />

                    <!-- Button to Reject -->
                    <button name="action_reject_offer"
                            string="Reject All"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'deal_received'"
                    />

                    <!-- Button to Cancel -->
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"
                            invisible="state in ['draft', 'cancelled', 'sold', 'rented']"
                            confirm="Are you sure you want to cancel?"
                    />

                    <!-- statusbar -->
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,available,deal_received,deal_confirmed,agreement_pending,sold,cancelled"
                           invisible="property_type != 'sale' or state == 'sold'"
                    />

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,available,deal_received,deal_confirmed,agreement_pending,sold"
                           invisible="state != 'sold'"
                    />

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,available,deal_received,deal_confirmed,contract_pending,rented,cancelled"
                           invisible="property_type != 'rent' or state == 'rented'"
                    />

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,available,deal_received,deal_confirmed,contract_pending,rented"
                           invisible="state != 'rented'"
                    />
                </header>


                <sheet>
                    <!-- Smart Button -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_payments" type="object" string="Payments"
                                class="oe_stat_button" icon="fa-dollar">
                            <field string="Payments" name="payment_count" widget="statinfo"/>
                        </button>
                        <button name="action_view_all_offers" type="object" string="Deals"
                                class="oe_stat_button" icon="fa-handshake-o">
                            <field string="Deals" name="offer_count" widget="statinfo"/>
                        </button>
                    </div>

                    <h1>
                        <field name="name" placeholder="e.g. Sun Bungalows" string="Property Name" width="150"
                               readonly="state != 'draft'"/>
                    </h1>

                    <group>
                        <group>
                            <strong>Address</strong>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"
                                       readonly="state != 'draft'"/>
                                <field name="street2" placeholder="Street2..." class="o_address_street"
                                       readonly="state != 'draft'"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="state != 'draft'"/>
                                <field name="city" placeholder="City" class="o_address_city"
                                       readonly="state != 'draft'"/>
                                <field name="state_id" placeholder="State" class="o_address_state"
                                       readonly="state != 'draft'"/>
                                <field name="country_id" placeholder="Country" class="o_address_country"
                                       readonly="state != 'draft'"/>
                            </div>
                        </group>
                        <group>
                            <field name="owner_id" placeholder="Owner name" readonly="state != 'draft'"/>
                            <field name="property_type" placeholder="Property Type" readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1" readonly="state != 'draft'"/>
                            <field name="sale_price" widget="monetary" readonly="state != 'draft'"
                                   invisible=" property_type != 'sale'" class="fs-10 fw-bold"/>
                            <field name="rent_price" widget="monetary" readonly="state != 'draft'"
                                   invisible=" property_type != 'rent'" class="fs-10 fw-bold"/>
                            <label string="Square" for="square_fit"/>
                            <div class="o_row">
                                <field name="square_fit" class="oe_inline" style="width: 100px;"/>
                                <span class="oe_inline">per</span>
                                <field name="per_units" class="oe_inline" style="width: 80px;"/>
                            </div>
                        </group>
                    </group>

                    <notebook>
                        <page string="Offer Details">
                            <field name="offer_ids" readonly="1">
                                <list>
                                    <field name="original_owner_id" optional="hide"/>
                                    <field name="partner_id" string="Buyer/Tenant"/>
                                    <field name="state" string="Status" widget="badge"
                                           decoration-info="state == 'interested'"
                                           decoration-success="state == 'closed'"
                                           decoration-primary="state == 'accepted'"
                                           decoration-danger="state == 'cancelled' or state == 'rejected'"/>
                                    <field name="offer_date"/>
                                    <field name="currency_id" invisible="1" nolabel="1"/>
                                    <field name="your_price" string="Customer Price" widget="monetary"
                                           class="fs-10 fw-bold" width="300"/>
                                </list>
                            </field>
                        </page>

                        <page string="Payments">
                            <field name="payment_ids" readonly="1"/>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="property_list_view" model="ir.ui.view">
        <field name="name">property.list.view</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Property"/>
                <field name="owner_id" string="Owner"/>
                <field name="property_type" string="Property Type" class="fs-10 fw-bold"/>
                <field name="state" string="Status" widget="badge"
                       decoration-info="state == 'deal_received' or state == 'deal_confirmed'"
                       decoration-warning="state == 'contract_pending' or state == 'agreement_pending'"
                       decoration-danger="state == 'cancelled'"
                       decoration-success="state == 'sold' or state == 'rented'"/>
                <field name="currency_id" invisible="1" nolabel="1"/>
                <field name="amount" widget="monetary" readonly="state != 'draft'" class="fw-bold"
                       string="Amount"/>
                <field name="country_id"/>
            </list>
        </field>
    </record>

    <record id="search_property_view" model="ir.ui.view">
        <field name="name">search.property.view</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Listed To Sale" name="property_type" domain="[('property_type', '=', 'sale')]"/>
                <filter string="Listed To Rent" name="property_type" domain="[('property_type', '=', 'rent')]"/>
                <filter string="Rented Properties" name="property_type" domain="[('state', '=', 'rented')]"/>
                <filter string="Sold Properties" name="property_type" domain="[('state', '=', 'sold')]"/>
                <filter name="property_type" string="Sale and Rent" context="{'group_by': 'property_type'}"/>
                <filter name="state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_property_set_draft" model="ir.actions.server">
        <field name="name">Set Property Draft</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">action = records.state_to_draft_server_action()</field>
    </record>

    <record id="action_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">property</field>
        <field name="view_mode">list,form,search</field>
    </record>
</odoo>