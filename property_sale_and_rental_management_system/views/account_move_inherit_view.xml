<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="account_move_form_view" model="ir.ui.view">

        <field name="name">account.move.form.view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_shipping_id']" position="before">
                <field name="f_description" />
            </xpath>
            <xpath expr="//notebook/page[@name='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='tax_ids']" position="after">
                <field name="s_description"/>
            </xpath>
        </field>

    </record>

</odoo>