<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="rent_line_form_view" model="ir.ui.view">
        <field name="name">property.rent.lines.form.view</field>
        <field name="model">property.rent.lines</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="property_id" readonly="1"/>
                            <field name="tenant_id" readonly="1"/>
                            <field name="due_date" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="payment_reference" readonly="1"/>
                            <field name="payment_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="rent_line_list_view" model="ir.ui.view">
        <field name="name">property.rent.lines.list.view</field>
        <field name="model">property.rent.lines</field>
        <field name="arch" type="xml">
            <list>
                <field name="property_id"/>
                <field name="tenant_id"/>
                <field name="due_date"/>
                <field name="amount" widget="monetary"/>
                <field name="status"
                       widget="badge"
                       decoration-warning="status == 'payment_due'"
                       decoration-success="status == 'paid'"/>
            </list>
        </field>
    </record>

    <record id="action_rent_order_line" model="ir.actions.act_window">
        <field name="name">Rent Lines</field>
        <field name="res_model">property.rent.lines</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>