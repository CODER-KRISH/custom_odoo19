<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════════
         FORM VIEW
    ════════════════════════════════════════════════════════════════════ -->
    <record id="view_announcement_form" model="ir.ui.view">
        <field name="name">announcement.form</field>
        <field name="model">announcement</field>
        <field name="arch" type="xml">
            <form string="Announcement">
                <header>
                    <button name="action_publish"
                            string="Publish"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_expire"
                            string="Mark Expired"
                            type="object"
                            invisible="state != 'published'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('cancelled', 'expired')"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state == 'draft'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,published,expired"/>
                </header>

                <sheet>
                    <h1>
                        <field name="title" placeholder="Announcement Title…" readonly="state != 'draft'"/>
                    </h1>

                    <group>
                        <group string="General Info">
                            <field name="announcement_type" readonly="state != 'draft'"/>
                            <field name="audience" readonly="state != 'draft'"/>
                            <field name="academic_year" readonly="state != 'draft'"/>
                        </group>
                        <group string="Dates &amp; Author">
                            <field name="published_by" readonly="1"/>
                            <field name="publish_date" readonly="state != 'draft'"/>
                            <field name="expiry_date" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <h3>
                                <field name="description" widget="html" readonly="state != 'draft'"/>
                            </h3>
                        </page>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         LIST VIEW
    ════════════════════════════════════════════════════════════════════ -->
    <record id="view_announcement_list" model="ir.ui.view">
        <field name="name">announcement.list</field>
        <field name="model">announcement</field>
        <field name="arch" type="xml">
            <list string="Announcements">
                <field name="name" optional="hide"/>
                <field name="title" class="fw-bold"/>
                <field name="announcement_type"/>
                <field name="audience"/>
                <field name="academic_year"/>
                <field name="publish_date" width="150" class="fw-bold"/>
                <field name="expiry_date" width="150" class="fw-bold"/>
                <field name="published_by"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'published'"
                       decoration-warning="state == 'expired'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>


    <!-- ═════════════════════════════════  ═══════════════════════════════════
         ACTION
    ════════════════════════════════════════════════════════════════════ -->
    <record id="action_announcement" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">announcement</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Your First Announcement!
            </p>
        </field>
    </record>

</odoo>