<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="stock_picking_form_view" model="ir.ui.view">
        <field name="name">stock.picking.form.view</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group" position="inside">
                <group>
                    <group string="Information Group">
                        <field name="sale_order_number"/>
                        <field name="customer_name"/>
                        <field name="promised_delivery_date"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="stock_picking_list_view" model="ir.ui.view">
        <field name="name">stock.picking.list.view</field>
        <field name="model">stock.picking</field>
        <field name="type">list</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="customer_name"/>
                <field name="promised_delivery_date"/>
            </xpath>
        </field>
    </record>

</odoo>