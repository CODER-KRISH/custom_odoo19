    <record id="standard_kanban_view" model="ir.ui.view">
        <field name="name">standard.kanban.view</field>
        <field name="model">standard</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="class_name"/>
                <field name="standard_student_count"/>
                <field name="standard_teacher_count"/>
                <field name="standard_subjects_count"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click p-3">
                            <div class="mb-2">
                                <strong class="fs-4">
                                    <field name="class_name"/>
                                </strong>
                            </div>

                            <div class="row text-center mt-3">
                                <div class="col-4">
                                    <div class="fw-bold">
                                        <field name="standard_student_count"/>
                                    </div>
                                    <small>Students</small>
                                </div>

                                <div class="col-4">
                                    <div class="fw-bold">
                                        <field name="standard_teacher_count"/>
                                    </div>
                                    <small>Teachers</small>
                                </div>

                                <div class="col-4">
                                    <div class="fw-bold">
                                        <field name="standard_subjects_count"/>
                                    </div>
                                    <small>Subjects</small>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!--    Action-->
    <record id="standard_action" model="ir.actions.act_window">
        <field name="name">Standard</field>
        <field name="res_model">standard</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Standard!
            </p>
        </field>
    </record>
</odoo>