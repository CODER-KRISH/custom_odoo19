<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="view_base_users_from" model="ir.ui.view">
        <field name="name">view.base.users.from</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/div[1]/button[@name='action_show_groups']" position="after">
                <button name="view_subscriptions_order" type="object" class="oe_stat_button" icon="fa-dollar">
                    <field string="Active Subscriptions" name="subscription_counter" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>